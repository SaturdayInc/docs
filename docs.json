{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Saturday API",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#1aabb8",
    "light": "#8FC5CE",
    "dark": "#0e7e8a"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "error-handling",
              "rate-limiting"
            ]
          },
          {
            "group": "Core Guides",
            "pages": [
              "guides/nutrition-calculation",
              "guides/athletes",
              "guides/activities",
              "guides/freemium-model",
              "guides/safety"
            ]
          },
          {
            "group": "Integration Guides",
            "pages": [
              "guides/ai-coach",
              "guides/webhooks",
              "guides/oauth2",
              "guides/organizations",
              "guides/batch-operations",
              "guides/mcp-integration"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "guides/feature-gates",
              "guides/data-policy",
              "guides/deployment"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://forum.saturday.fit",
          "icon": "people-group"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api@saturday.fit"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "mailto:api@saturday.fit?subject=API%20Access%20Request"
    }
  },
  "footer": {
    "socials": {
      "website": "https://saturday.fit",
      "youtube": "https://youtube.com/@saturdayfuel"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor"]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "indexHiddenPages": false
  },
  "metadata": {
    "og:site_name": "Saturday API Documentation",
    "twitter:site": "@saturdayfuel"
  }
}
