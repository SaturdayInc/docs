{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Saturday API",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#1aabb8",
    "light": "#8FC5CE",
    "dark": "#0e7e8a"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Coaching",
        "icon": "whistle",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "coaching/overview",
              "coaching/become-a-coach",
              "coaching/first-athlete"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "coaching/billing/who-pays",
              "coaching/billing/coach-paid-athletes",
              "coaching/billing/take-over-relinquish",
              "coaching/billing/volume-discount"
            ]
          },
          {
            "group": "Roster & alerts",
            "pages": [
              "coaching/roster/flags-and-groups",
              "coaching/roster/ai-report",
              "coaching/roster/configuring-alerts"
            ]
          },
          {
            "group": "Team & assistants",
            "pages": [
              "coaching/team/add-assistants",
              "coaching/team/assign-athletes",
              "coaching/team/team-rollup",
              "coaching/team/permissions"
            ]
          },
          {
            "group": "Nutrition curriculum",
            "pages": [
              "coaching/nutrition/overview",
              "coaching/nutrition/bottling-fill-mix",
              "coaching/nutrition/gluc-fruc-ratio",
              "coaching/nutrition/eco-mode-vs-products",
              "coaching/nutrition/setup-dials"
            ]
          }
        ]
      },
      {
        "tab": "API Guides",
        "icon": "code",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "access",
              "quickstart",
              "authentication",
              "error-handling",
              "rate-limiting"
            ]
          },
          {
            "group": "Core Guides",
            "pages": [
              "guides/nutrition-calculation",
              "guides/athletes",
              "guides/activities",
              "guides/freemium-model",
              "guides/onboarding",
              "guides/athlete-onboarding-journey",
              "guides/safety"
            ]
          },
          {
            "group": "Integration Guides",
            "pages": [
              "guides/ai-coach",
              "guides/webhooks",
              "guides/oauth2",
              "guides/organizations",
              "guides/batch-operations",
              "guides/mcp-integration"
            ]
          },
          {
            "group": "Coach API",
            "pages": [
              "guides/coach-api",
              "guides/coach-connector"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "guides/feature-gates",
              "guides/data-policy",
              "guides/deployment"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://forum.saturday.fit",
          "icon": "people-group"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/errors",
      "destination": "/error-handling"
    },
    {
      "source": "/errors/:code",
      "destination": "/error-handling"
    },
    {
      "source": "/api-reference",
      "destination": "/guides/nutrition-calculation"
    },
    {
      "source": "/docs/errors",
      "destination": "/error-handling"
    },
    {
      "source": "/docs/authentication",
      "destination": "/authentication"
    },
    {
      "source": "/docs/rate-limiting",
      "destination": "/rate-limiting"
    },
    {
      "source": "/docs/feature-gates",
      "destination": "/guides/feature-gates"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api@saturday.fit"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "mailto:api@saturday.fit?subject=API%20Access%20Request"
    }
  },
  "footer": {
    "socials": {
      "website": "https://saturday.fit",
      "youtube": "https://youtube.com/@saturdayfuel"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "indexHiddenPages": false
  },
  "metadata": {
    "og:site_name": "Saturday API Documentation",
    "twitter:site": "@saturdayfuel"
  }
}